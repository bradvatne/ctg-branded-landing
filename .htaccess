# Clubtech branded landing — Apache runtime config (ignored by GitHub Pages)
ErrorDocument 404 /404.html

# Retired feature routes. Keep the HTML stubs as non-Apache fallbacks, but the
# production server must send a real permanent redirect before serving them.
RedirectMatch 301 ^/booking/?$ /platform/#booking
RedirectMatch 301 ^/operations/?$ /platform/#operations
RedirectMatch 301 ^/intelligence/?$ /grow/#guest-data
